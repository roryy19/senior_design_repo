# Enable Bluetooth (NimBLE stack — lighter than BlueDroid)
CONFIG_BT_ENABLED=y
CONFIG_BT_NIMBLE_ENABLED=y
CONFIG_BT_NIMBLE_MAX_CONNECTIONS=1

# Disable BlueDroid (we use NimBLE instead)
CONFIG_BT_BLUEDROID_ENABLED=n

# Set the device name that appears during scanning
CONFIG_BT_NIMBLE_SVC_GAP_DEVICE_NAME="ObstacleBelt"
